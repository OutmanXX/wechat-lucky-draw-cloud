.draw-page {
  padding: 24rpx;
  display: grid;
  gap: 20rpx;
}

.small-title {
  font-size: 34rpx;
}

.list-card {
  margin-bottom: 24rpx;
}

.person-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(24, 32, 24, 0.08);
}

.person-row:last-child {
  border-bottom: 0;
}

.person-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.person-name {
  font-size: 30rpx;
  font-weight: 700;
}

.person-meta {
  margin-top: 8rpx;
  color: #566055;
  font-size: 24rpx;
}
