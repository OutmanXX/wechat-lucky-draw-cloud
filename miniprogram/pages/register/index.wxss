.register-page {
  background-position: center;
  background-size: cover;
}

.overlay {
  min-height: 100vh;
  padding: 48rpx 24rpx;
  background: linear-gradient(180deg, rgba(18, 34, 26, 0.28), rgba(18, 34, 26, 0.52));
}

.avatar-box {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
}

.avatar-button {
  width: 180rpx;
  height: 180rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  overflow: hidden;
}

.avatar-button::after {
  border: 0;
}

.avatar-image,
.avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f8f66;
  font-weight: 700;
}

.admin-entry {
  margin-top: 18rpx;
}

.admin-panel {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.22);
}
