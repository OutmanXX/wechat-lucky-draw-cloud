page {
  background: #f7f3eb;
  color: #1b231c;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 24rpx 56rpx rgba(20, 35, 25, 0.08);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 12rpx;
  color: #566055;
  font-size: 28rpx;
}

.primary-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1f8f66, #38a573);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-btn {
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #ecf7f0;
  color: #19523f;
  font-size: 30rpx;
  font-weight: 700;
}

.field {
  display: block;
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
}
